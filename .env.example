# =============================================================================
# RePrime Command Center — environment variable template
# =============================================================================
#
# This is a PUBLIC repository. NEVER commit real values to this file.
# All values here are placeholders. Set real values either in:
#   - .env.local (local dev only, gitignored)
#   - Vercel project Environment Variables (production + preview)
#
# Setting any var to an empty string is treated the same as missing.
# See docs/ENVIRONMENT_AUDIT.md for full per-var documentation.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. SUPABASE (auth + DB) — required for the app to render anything
# -----------------------------------------------------------------------------
# Public values (browser sees these). The URL is not a secret; the anon key
# is RLS-gated and safe to expose.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — full DB access, bypasses RLS. SERVER-ONLY. Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# Optional duplicate of NEXT_PUBLIC_SUPABASE_URL — legacy reads. Setting it
# is harmless; can be omitted once code is consolidated.
SUPABASE_URL=


# -----------------------------------------------------------------------------
# 2. APP BASE URL — required for invitation links + OAuth callbacks
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=


# -----------------------------------------------------------------------------
# 3. AUTH — REPRIME access code
# -----------------------------------------------------------------------------
# The single-user kiosk login flow. POST /api/auth/code with this value mints
# a Supabase session for g@reprime.com.
AUTH_ACCESS_CODE=


# -----------------------------------------------------------------------------
# 4. AI providers
# -----------------------------------------------------------------------------
# Anthropic Claude — powers Nora, drafts, summaries, concierge messages.
ANTHROPIC_API_KEY=

# OpenAI — Whisper for English voice transcription.
OPENAI_API_KEY=

# Groq — used for Hebrew voice-in (cheaper/faster than OpenAI for non-English).
GROQ_API_KEY=


# -----------------------------------------------------------------------------
# 5. GOOGLE — Gmail + Calendar + Sheets
# -----------------------------------------------------------------------------
# Primary OAuth credentials. Canonical names — use these going forward.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Refresh token for g@reprime.com. Issued once, persists. Verify ownership
# via /api/center/gmail-whoami.
GOOGLE_REFRESH_TOKEN=

# Optional second account refresh token (e.g., a personal inbox).
GOOGLE_REFRESH_TOKEN_2=

# Legacy aliases — code reads these as a fallback. New deploys can leave empty
# once the consolidation in STEP 8 lands.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail Pub/Sub push verification (OIDC audience). Optional but recommended.
GMAIL_PUSH_AUDIENCE=

# Google Sheet tab name where outreach is exported. Optional.
SHEETS_OUTREACH_TAB=


# -----------------------------------------------------------------------------
# 6. UPSTASH REDIS — caching + dedup
# -----------------------------------------------------------------------------
# Without these, getRedis() returns null and every consumer falls back to
# uncached behavior. App still works, just slower / more API hits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# -----------------------------------------------------------------------------
# 7. COMMS — WhatsApp (Timelines.ai bridge) + SMS (Quo/OpenPhone) + iMessage
# -----------------------------------------------------------------------------
# Timelines.ai — bridges WhatsApp Business API. Powers /cockpit WhatsApp panel.
TIMELINES_API_KEY=

# Quo / OpenPhone — SMS send + webhook. Used by the 305-area QUO line.
QUO_API_KEY=
QUO_SEND_FROM=                 # E.164 sender, e.g. +13057784861
QUO_WEBHOOK_SECRET=            # Single signing secret
QUO_WEBHOOK_SECRETS=           # Comma-separated list for rotation

# BlueBubbles webhook — only used if iMessage Mac is online and reachable.
BLUEBUBBLES_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# 8. ZOOM — account-credentials OAuth
# -----------------------------------------------------------------------------
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Webhook signature secret — used to verify /api/zoom/webhook payloads.
ZOOM_WEBHOOK_SECRET_TOKEN=

# Fallback URL if Zoom create-meeting fails. Optional.
STATIC_ZOOM_FALLBACK_URL=


# -----------------------------------------------------------------------------
# 9. VOICE — text-to-speech (ElevenLabs) + Hebrew zmanim
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Zip code for Hebcal candle-lighting / havdalah lookup. Defaults to Postville,
# IA (52162) when unset.
ZMANIM_ZIP=


# -----------------------------------------------------------------------------
# 10. CRM — Pipedrive + enrichment
# -----------------------------------------------------------------------------
PIPEDRIVE_API_TOKEN=

# Apollo for contact enrichment. Falls back to stub if missing.
APOLLO_API_KEY=


# -----------------------------------------------------------------------------
# 11. TRANSACTIONAL EMAIL — SendGrid
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=           # e.g. notifications@reprime.com (must be verified)
SENDGRID_FROM_NAME=            # e.g. RePrime


# -----------------------------------------------------------------------------
# 12. OPERATIONS / OBSERVABILITY
# -----------------------------------------------------------------------------
# Cron auth — bearer token Vercel sends on scheduled invocations.
CRON_SECRET=

# Sentry DSNs — server + client.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Slack webhook for non-urgent alerts (digests, etc.). Optional.
SLACK_WEBHOOK_URL=

# PagerDuty Events API v2 routing key (incident dispatch). Optional.
PAGERDUTY_ROUTING_KEY=

# Outbound alert chat channel id (Center-side notification fanout).
CENTER_ALERT_CHAT_ID=

# Center kiosk password — gates /api/center/* via x-center-pass header.
CENTER_PASSWORD=

# Captain token — gates the Chrome extension's /api/invitations mint call.
CAPTAIN_API_TOKEN=

# Headless Chromium executable path (used by /api/cron/inforuptcy-poll).
CHROME_PATH=


# -----------------------------------------------------------------------------
# 13. INFORUPTCY — bankruptcy watchlist
# -----------------------------------------------------------------------------
INFORUPTCY_EMAIL=
INFORUPTCY_PASSWORD=


# =============================================================================
# Auto-populated by Vercel / Next.js — DO NOT SET MANUALLY:
#   NEXT_RUNTIME, VERCEL_ENV, VERCEL_DEPLOYMENT_TS, VERCEL_GIT_COMMIT_SHA
# =============================================================================
