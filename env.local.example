# RePrime Command Center — local env template
# Copy to .env.local and fill values (sources in KEYS.md / 1Password / Vercel project-7e87w).
# .env.local is gitignored — never commit real values.

# ── REQUIRED to boot (auth middleware needs these) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI / voice ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Messaging / phone / email ──────────────────────────────────────────────
TIMELINES_API_KEY=
QUO_API_KEY=
QUO_WEBHOOK_SECRET=
QUO_WEBHOOK_SECRETS=
BLUEBUBBLES_WEBHOOK_SECRET=
BB_CALL_SECRET=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=

# ── CRM / enrichment ───────────────────────────────────────────────────────
PIPEDRIVE_API_TOKEN=
APOLLO_API_KEY=

# ── Google (Calendar + Gmail) / Zoom ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
STATIC_ZOOM_FALLBACK_URL=

# ── Cache / queue / ops ────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CRON_SECRET=
CAPTAIN_API_TOKEN=
PAGERDUTY_ROUTING_KEY=
SLACK_WEBHOOK_URL=
SHEETS_OUTREACH_TAB=

# ── Research connectors ────────────────────────────────────────────────────
INFORUPTCY_EMAIL=
INFORUPTCY_PASSWORD=
CENSUS_API_KEY=
COURTLISTENER_API_TOKEN=
SEC_EDGAR_USER_AGENT=RePrime Group g@reprime.com
CHROME_PATH=

# ── Observability (optional) ───────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── App ────────────────────────────────────────────────────────────────────
