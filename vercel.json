{
  "redirects": [
    {
      "source": "/((?!api/|invite/|v/).*)",
      "has": [{ "type": "host", "value": "reprime-terminal.com" }],
      "destination": "https://reprime.com/$1",
      "permanent": true
    },
    {
      "source": "/((?!api/|invite/|v/).*)",
      "has": [{ "type": "host", "value": "www.reprime-terminal.com" }],
      "destination": "https://reprime.com/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/center-drain",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/cron/dispatch-alerts",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/secretary/poll-overdue",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/bucket/fire-reminders",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/inforuptcy-poll",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/slack-digest",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/meeting-verify",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/center/reconcile",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/gmail-watch-arm",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "app/api/cron/inforuptcy-poll/route.ts": {
      "memory": 2048,
      "maxDuration": 300
    }
  }
}
